generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  schemas  = ["public", "core", "raw", "kpi"]
}

model User {
  id           String       @id
  name         String?
  email        String       @unique
  passwordHash String       @map("password_hash")
  isSuperAdmin Boolean      @default(false) @map("is_super_admin")
  isActive     Boolean      @default(true) @map("is_active")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @map("updated_at")
  memberships  Membership[]

  @@map("users")
  @@schema("core")
}

model Tenant {
  id                String       @id
  name              String
  slug              String       @unique
  isActive          Boolean      @default(true) @map("is_active")
  createdAt         DateTime     @default(now()) @map("created_at")
  updatedAt         DateTime     @map("updated_at")
  apiBaseUrl        String       @default("") @map("api_base_url")
  apiKey            String       @default("") @map("api_key")
  backendClientId   String?      @map("backend_client_id")
  backendLastError  String?      @map("backend_last_error")
  backendLastSyncAt DateTime?    @map("backend_last_sync_at")
  backendSyncStatus String       @default("PENDING") @map("backend_sync_status")
  backendClient     SinapseClient? @relation("TenantBackendClient", fields: [backendClientId], references: [id])
  memberships       Membership[]
  refreshJobs       RefreshJob[]

  @@index([backendClientId], map: "tenants_backend_client_id_idx")
  @@map("tenants")
  @@schema("core")
}

model Membership {
  id        String   @id
  tenantId  String   @map("tenant_id")
  userId    String   @map("user_id")
  role      Role
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([tenantId, userId])
  @@map("memberships")
  @@schema("core")
}

model SinapseClient {
  id         String   @id
  slug       String   @unique
  name       String
  domainUuid String   @map("domain_uuid")
  apiBaseUrl String   @map("api_base_url")
  apiKey     String   @map("api_key")
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @map("updated_at")
  branches   Branch[]
  budgetFacts BudgetFact[]
  callFacts  CallFact[]
  contacts   Contact[]
  saleFacts  SaleFact[]
  tags       Tag[]
  tickets    Ticket[]
  kpiAvailabilities KpiAvailability[]
  kpiBreakdowns KpiBreakdown[]
  kpiCalculationRuns KpiCalculationRun[]
  kpiSnapshots KpiSnapshot[]
  refreshJobs RefreshJob[]
  tenants    Tenant[] @relation("TenantBackendClient")
  whatsappCities WhatsAppCity[]
  whatsappDepartmentMappings WhatsAppDepartmentMapping[]

  @@map("sinapse_clients")
  @@schema("core")
}

model Branch {
  id                  Int           @id @default(autoincrement())
  name                String
  address             String
  phone               String
  cnpj                String
  clientId            String        @map("client_id")
  erpId               BigInt        @map("erp_id")
  telephonyDomainUuid String?       @map("telephony_domain_uuid")
  flwDepartmentId     String?       @unique(map: "branches_flw_department_id_key") @map("flw_department_id") @db.Uuid
  client              SinapseClient @relation(fields: [clientId], references: [id])
  budgetFacts BudgetFact[]
  callFacts   CallFact[]
  saleFacts SaleFact[]
  employees Employee[]
  messagingSessions MessagingSession[]

  @@map("branches")
  @@schema("core")
}

model Employee {
  id              Int      @id @default(autoincrement())
  name            String
  extensionNumber String?  @map("extension_number")
  extensionUuid   String?  @map("extension_uuid")
  erpId           BigInt   @map("erp_id")
  chatId          String?  @map("chat_id")
  dkwWebhook      String?  @map("dkw_webhook")
  isNonCommercial Boolean  @default(false) @map("is_non_commercial")
  isActive        Boolean  @default(true) @map("is_active")
  branchId        Int      @map("branch_id")
  branch          Branch   @relation(fields: [branchId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([branchId], map: "employees_branch_id_idx")
  @@index([erpId], map: "employees_erp_id_idx")
  @@map("employees")
  @@schema("core")
}

model Session {
  id                       String      @id
  ticketId                 String      @map("ticket_id")
  externalTrackingId       Int?        @map("external_tracking_id")
  type                     SessionType
  startedAt                DateTime    @map("started_at")
  endedAt                  DateTime?   @map("ended_at")
  assignedUserName         String?     @map("assigned_user_name")
  assignedUserEmail        String?     @map("assigned_user_email")
  createdAt                DateTime    @default(now()) @map("created_at")
  updatedAt                DateTime    @default(now()) @map("updated_at")
  originImportedTrackingId String?     @map("origin_imported_tracking_id")
  processingVersion        String?     @map("processing_version")
  source                   String?
  createdAtExternal        DateTime?   @map("created_at_external")
  ticket                   Ticket      @relation(fields: [ticketId], references: [id])
  messages                 Message[]

  @@index([ticketId], map: "sessions_ticket_id_idx")
  @@map("sessions")
  @@schema("core")
}

model Message {
  id                String             @id
  ticketId          String             @map("ticket_id")
  sessionId         String?            @map("session_id")
  externalMessageId String             @map("external_message_id")
  key               String?
  body              String
  fromMe            Boolean            @map("from_me")
  mediaUrl          String?            @map("media_url")
  mediaType         String?            @map("media_type")
  createdAtExternal DateTime           @map("created_at_external")
  updatedAtExternal DateTime           @map("updated_at_external")
  rawJson           Json?              @map("raw_json")
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @default(now()) @map("updated_at")
  senderType        MessageSenderType  @map("sender_type")
  session           Session?           @relation(fields: [sessionId], references: [id])
  ticket            Ticket             @relation(fields: [ticketId], references: [id])

  @@index([ticketId], map: "messages_ticket_id_idx")
  @@index([sessionId], map: "messages_session_id_idx")
  @@map("messages")
  @@schema("core")
}

model Ticket {
  id                            String         @id
  externalUuid                  String         @map("external_uuid")
  externalTicketId              Int?           @map("external_ticket_id")
  status                        String?
  contactName                   String?        @map("contact_name")
  contactNumber                 String?        @map("contact_number")
  contactExternalId             Int?           @map("contact_external_id")
  socialConnectionId            Int?           @map("social_connection_id")
  companyId                     Int?           @map("company_id")
  createdAtExternal             DateTime?      @map("created_at_external")
  updatedAtExternal             DateTime?      @map("updated_at_external")
  lastImportedMessageCreatedAt  DateTime?      @map("last_imported_message_created_at")
  createdAt                     DateTime       @default(now()) @map("created_at")
  updatedAt                     DateTime       @default(now()) @map("updated_at")
  clientId                      String         @map("client_id")
  contactId                     BigInt?        @map("contact_id")
  isGroup                       Boolean        @default(false) @map("is_group")
  client                        SinapseClient  @relation(fields: [clientId], references: [id])
  contact                       Contact?       @relation(fields: [contactId], references: [id])
  messages                      Message[]
  sessions                      Session[]

  @@index([clientId], map: "tickets_client_id_idx")
  @@index([contactId], map: "tickets_contact_id_idx")
  @@map("tickets")
  @@schema("core")
}

model Contact {
  id                 BigInt        @id
  clientId           String        @map("client_id")
  companyId          BigInt?       @map("company_id")
  name               String?
  number             String?
  email              String?
  isGroup            Boolean       @default(false) @map("is_group")
  socialConnectionId BigInt?       @map("social_connection_id")
  profilePicUrl      String?       @map("profile_pic_url")
  createdAtRemote    DateTime?     @map("created_at_remote")
  updatedAtRemote    DateTime?     @map("updated_at_remote")
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @default(now()) @map("updated_at")
  client             SinapseClient @relation(fields: [clientId], references: [id])
  contactTags        ContactTag[]
  tickets            Ticket[]

  @@index([clientId], map: "contacts_client_id_idx")
  @@map("contacts")
  @@schema("core")
}

model Tag {
  id         BigInt        @id
  clientId   String        @map("client_id")
  companyId  BigInt?       @map("company_id")
  name       String
  color      String?
  createdAt  DateTime      @default(now()) @map("created_at")
  updatedAt  DateTime      @default(now()) @map("updated_at")
  client     SinapseClient @relation(fields: [clientId], references: [id])
  contactTags ContactTag[]

  @@index([clientId], map: "tags_client_id_idx")
  @@map("tags")
  @@schema("core")
}

model ContactTag {
  clientId  String    @map("client_id")
  contactId BigInt    @map("contact_id")
  tagId     BigInt    @map("tag_id")
  createdAt DateTime  @default(now()) @map("created_at")
  contact   Contact   @relation(fields: [contactId], references: [id])
  tag       Tag       @relation(fields: [tagId], references: [id])

  @@id([clientId, contactId, tagId])
  @@index([contactId], map: "contact_tags_contact_id_idx")
  @@index([tagId], map: "contact_tags_tag_id_idx")
  @@map("contact_tags")
  @@schema("core")
}

model RefreshJob {
  id            BigInt        @id @default(autoincrement())
  tenantId      String        @map("tenant_id")
  clientId      String        @map("client_id")
  slug          String
  triggerType   String        @map("trigger_type")
  requestedFrom DateTime      @map("requested_from") @db.Date
  requestedTo   DateTime      @map("requested_to") @db.Date
  status        String
  requestedAt   DateTime      @default(now()) @map("requested_at")
  startedAt     DateTime?     @map("started_at")
  finishedAt    DateTime?     @map("finished_at")
  errorMessage  String?       @map("error_message")
  resultsJson   Json?         @map("results_json")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @default(now()) @map("updated_at")
  tenant        Tenant        @relation(fields: [tenantId], references: [id])
  client        SinapseClient @relation(fields: [clientId], references: [id])

  @@index([tenantId, requestedAt], map: "refresh_jobs_tenant_requested_idx")
  @@index([clientId, requestedAt], map: "refresh_jobs_client_requested_idx")
  @@index([status, requestedAt], map: "refresh_jobs_status_requested_idx")
  @@map("refresh_jobs")
  @@schema("core")
}

model CallFact {
  id                 BigInt        @id @default(autoincrement())
  clientId           String        @map("client_id")
  branchId           Int?          @map("branch_id")
  sourceTable        String        @map("source_table")
  sourceRecordId     Int           @map("source_record_id")
  domainUuid         String?       @map("domain_uuid")
  xmlCdrUuid         String?       @map("xml_cdr_uuid")
  direction          String?
  callerNumber       String?       @map("caller_number")
  destinationNumber  String?       @map("destination_number")
  extensionUuid      String?       @map("extension_uuid")
  startedAt          DateTime      @map("started_at")
  endedAt            DateTime?     @map("ended_at")
  durationSeconds    Decimal       @map("duration_seconds") @db.Decimal(19, 4)
  recordPath         String?       @map("record_path")
  recordName         String?       @map("record_name")
  hangupCause        String?       @map("hangup_cause")
  sipHangupDisposition String?     @map("sip_hangup_disposition")
  status             String?
  isInboundToCompany Boolean       @default(false) @map("is_inbound_to_company")
  isReceived         Boolean       @default(false) @map("is_received")
  isLost             Boolean       @default(false) @map("is_lost")
  agentResolutionType String?      @map("agent_resolution_type")
  agentResolutionKey String?       @map("agent_resolution_key")
  agentExtensionNumber String?     @map("agent_extension_number")
  payloadJson        Json          @default("{}") @map("payload_json")
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @default(now()) @map("updated_at")
  branch             Branch?       @relation(fields: [branchId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  client             SinapseClient @relation(fields: [clientId], references: [id])

  @@unique([clientId, sourceTable, sourceRecordId], map: "call_facts_client_source_record_key")
  @@index([clientId, startedAt], map: "call_facts_client_started_at_idx")
  @@index([clientId, branchId, startedAt], map: "call_facts_client_branch_started_at_idx")
  @@index([clientId, branchId, isInboundToCompany, startedAt], map: "call_facts_client_branch_inbound_started_idx")
  @@index([clientId, isInboundToCompany, startedAt], map: "call_facts_client_inbound_started_idx")
  @@index([clientId, isReceived, startedAt], map: "call_facts_client_received_started_idx")
  @@index([clientId, isLost, startedAt], map: "call_facts_client_lost_started_idx")
  @@index([clientId, agentResolutionKey, startedAt], map: "call_facts_client_agent_started_idx")
  @@index([clientId, status, startedAt], map: "call_facts_client_status_started_idx")
  @@index([clientId, direction, startedAt], map: "call_facts_client_direction_started_idx")
  @@index([clientId, startedAt, id], map: "call_facts_client_started_at_id_idx")
  @@map("call_facts")
  @@schema("core")
}

model BudgetFact {
  id                   BigInt            @id @default(autoincrement())
  clientId             String            @map("client_id")
  sourceTable          String            @map("source_table")
  sourceRecordId       Int               @map("source_record_id")
  branchName           String            @map("branch_name")
  branchId             Int?              @map("branch_id")
  sellerId             Int               @map("seller_id")
  sellerName           String            @map("seller_name")
  budgetDate           DateTime          @map("budget_date") @db.Date
  budgetDatetime       DateTime          @map("budget_datetime")
  cancellationDate     DateTime?         @map("cancellation_date") @db.Date
  cancelationTime      String?           @map("cancelation_time")
  closingDate          DateTime?         @map("closing_date") @db.Date
  statusRaw            String?           @map("status_raw")
  statusNormalized     String            @default("UNKNOWN") @map("status_normalized")
  channel              String?
  customerName         String            @map("customer_name")
  cpfCnpj              String?           @map("cpf_cnpj")
  valueAmount          Decimal           @map("value_amount") @db.Decimal(19, 4)
  sequential           BigInt?
  davId                BigInt            @map("dav_id")
  sequentialLinkedSale BigInt?           @map("sequential_linked_sale")
  payloadJson          Json              @default("{}") @map("payload_json")
  createdAt            DateTime          @default(now()) @map("created_at")
  updatedAt            DateTime          @default(now()) @map("updated_at")
  branch               Branch?           @relation(fields: [branchId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  client               SinapseClient     @relation(fields: [clientId], references: [id])
  drilldownRefs        KpiDrilldownRef[]

  @@unique([clientId, sourceTable, sourceRecordId], map: "budget_facts_client_source_record_key")
  @@index([clientId, budgetDate], map: "budget_facts_client_budget_date_idx")
  @@index([clientId, sellerId, budgetDate], map: "budget_facts_client_seller_budget_date_idx")
  @@index([clientId, branchId, budgetDate], map: "budget_facts_client_branch_budget_date_idx")
  @@map("budget_facts")
  @@schema("core")
}

model SaleFact {
  id                     BigInt        @id @default(autoincrement())
  clientId               String        @map("client_id")
  sourceTable            String        @map("source_table")
  sourceRecordId         Int           @map("source_record_id")
  branchName             String        @map("branch_name")
  branchId               Int?          @map("branch_id")
  sellerId               Int           @map("seller_id")
  sellerName             String        @map("seller_name")
  saleDate               DateTime      @map("sale_date") @db.Date
  saleDatetime           DateTime      @map("sale_datetime")
  statusRaw              String?       @map("status_raw")
  statusNormalized       String        @default("UNKNOWN") @map("status_normalized")
  channel                String?
  hasLinkedBudget        Boolean       @default(false) @map("has_linked_budget")
  linkedBudgetSourceRecordId Int?      @map("linked_budget_source_record_id")
  customerName           String        @map("customer_name")
  cpfCnpj                String?       @map("cpf_cnpj")
  valueAmount            Decimal       @map("value_amount") @db.Decimal(19, 4)
  sequential             BigInt?
  invoiceSerie           BigInt?       @map("invoice_serie")
  invoiceNumeric         BigInt?       @map("invoice_numeric")
  listDavsId             String?       @map("list_davs_id")
  payloadJson            Json          @default("{}") @map("payload_json")
  createdAt              DateTime      @default(now()) @map("created_at")
  updatedAt              DateTime      @default(now()) @map("updated_at")
  branch                 Branch?       @relation(fields: [branchId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  client                 SinapseClient @relation(fields: [clientId], references: [id])

  @@unique([clientId, sourceTable, sourceRecordId], map: "sale_facts_client_source_record_key")
  @@index([clientId, saleDate], map: "sale_facts_client_sale_date_idx")
  @@index([clientId, sellerId, saleDate], map: "sale_facts_client_seller_sale_date_idx")
  @@index([clientId, branchId, saleDate], map: "sale_facts_client_branch_sale_date_idx")
  @@map("sale_facts")
  @@schema("core")
}

model KpiDefinition {
  id              BigInt              @id @default(autoincrement())
  code            String              @unique
  family          String
  granularity     String
  name            String
  description     String?
  isActive        Boolean             @default(true) @map("is_active")
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @default(now()) @map("updated_at")
  availabilities  KpiAvailability[]
  breakdowns      KpiBreakdown[]
  calculationRuns KpiCalculationRun[]
  snapshots       KpiSnapshot[]

  @@map("definitions")
  @@schema("kpi")
}

model KpiAvailability {
  id           BigInt        @id @default(autoincrement())
  clientId     String        @map("client_id")
  definitionId BigInt        @map("definition_id")
  isEnabled    Boolean       @default(true) @map("is_enabled")
  availableAt  DateTime?     @map("available_at")
  metadataJson Json?         @map("metadata_json")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @default(now()) @map("updated_at")
  client       SinapseClient @relation(fields: [clientId], references: [id])
  definition   KpiDefinition @relation(fields: [definitionId], references: [id])

  @@unique([clientId, definitionId], map: "availability_client_definition_key")
  @@index([clientId, isEnabled], map: "availability_client_enabled_idx")
  @@map("availability")
  @@schema("kpi")
}

model KpiSnapshot {
  id            BigInt            @id @default(autoincrement())
  clientId      String            @map("client_id")
  definitionId  BigInt            @map("definition_id")
  periodType    String            @map("period_type")
  periodStart   DateTime          @map("period_start") @db.Date
  periodEnd     DateTime          @map("period_end") @db.Date
  metricKey     String            @map("metric_key")
  metricValue   Decimal           @map("metric_value") @db.Decimal(19, 4)
  dimensionsJson Json?            @map("dimensions_json")
  calculatedAt  DateTime          @default(now()) @map("calculated_at")
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @default(now()) @map("updated_at")
  client        SinapseClient     @relation(fields: [clientId], references: [id])
  definition    KpiDefinition     @relation(fields: [definitionId], references: [id])
  drilldownRefs KpiDrilldownRef[]

  @@unique([clientId, definitionId, periodType, periodStart, periodEnd, metricKey], map: "snapshots_period_metric_key")
  @@index([clientId, definitionId, periodStart, periodEnd], map: "snapshots_client_definition_period_idx")
  @@map("snapshots")
  @@schema("kpi")
}

model KpiBreakdown {
  id             BigInt            @id @default(autoincrement())
  clientId       String            @map("client_id")
  definitionId   BigInt            @map("definition_id")
  periodType     String            @map("period_type")
  periodStart    DateTime          @map("period_start") @db.Date
  periodEnd      DateTime          @map("period_end") @db.Date
  bucketDate     DateTime?         @map("bucket_date") @db.Date
  dimensionType  String            @map("dimension_type")
  dimensionKey   String?           @map("dimension_key")
  dimensionLabel String?           @map("dimension_label")
  metricKey      String            @map("metric_key")
  metricValue    Decimal           @map("metric_value") @db.Decimal(19, 4)
  sortOrder      Int               @default(0) @map("sort_order")
  payloadJson    Json?             @map("payload_json")
  calculatedAt   DateTime          @default(now()) @map("calculated_at")
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @default(now()) @map("updated_at")
  client         SinapseClient     @relation(fields: [clientId], references: [id])
  definition     KpiDefinition     @relation(fields: [definitionId], references: [id])
  drilldownRefs  KpiDrilldownRef[]

  @@index([clientId, definitionId, periodStart, periodEnd], map: "breakdowns_client_definition_period_idx")
  @@index([clientId, dimensionType, bucketDate], map: "breakdowns_client_dimension_bucket_idx")
  @@map("breakdowns")
  @@schema("kpi")
}

model KpiCalculationRun {
  id            BigInt            @id @default(autoincrement())
  clientId      String            @map("client_id")
  definitionId  BigInt?           @map("definition_id")
  runKey        String            @map("run_key")
  status        String
  periodType    String            @map("period_type")
  periodStart   DateTime          @map("period_start") @db.Date
  periodEnd     DateTime          @map("period_end") @db.Date
  recordsRead   Int               @default(0) @map("records_read")
  recordsWritten Int              @default(0) @map("records_written")
  startedAt     DateTime          @default(now()) @map("started_at")
  finishedAt    DateTime?         @map("finished_at")
  errorMessage  String?           @map("error_message")
  metadataJson  Json?             @map("metadata_json")
  client        SinapseClient     @relation(fields: [clientId], references: [id])
  definition    KpiDefinition?    @relation(fields: [definitionId], references: [id])
  drilldownRefs KpiDrilldownRef[]

  @@unique([clientId, runKey], map: "calculation_runs_client_run_key")
  @@index([clientId, startedAt], map: "calculation_runs_client_started_idx")
  @@map("calculation_runs")
  @@schema("kpi")
}

model KpiDrilldownRef {
  id               BigInt             @id @default(autoincrement())
  calculationRunId BigInt?            @map("calculation_run_id")
  snapshotId       BigInt?            @map("snapshot_id")
  breakdownId      BigInt?            @map("breakdown_id")
  budgetFactId     BigInt?            @map("budget_fact_id")
  refType          String             @map("ref_type")
  refKey           String?            @map("ref_key")
  refValue         String?            @map("ref_value")
  payloadJson      Json?              @map("payload_json")
  createdAt        DateTime           @default(now()) @map("created_at")
  breakdown        KpiBreakdown?      @relation(fields: [breakdownId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  budgetFact       BudgetFact?        @relation(fields: [budgetFactId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  calculationRun   KpiCalculationRun? @relation(fields: [calculationRunId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  snapshot         KpiSnapshot?       @relation(fields: [snapshotId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([snapshotId], map: "drilldown_refs_snapshot_idx")
  @@index([breakdownId], map: "drilldown_refs_breakdown_idx")
  @@index([budgetFactId], map: "drilldown_refs_budget_fact_idx")
  @@map("drilldown_refs")
  @@schema("kpi")
}

enum Role {
  OWNER
  ADMIN
  MANAGER
  VIEWER

  @@map("role")
  @@schema("core")
}

enum SessionType {
  CLOSED
  OPEN_REAL
  OPEN_WEAK
  UNTRACKED

  @@map("session_type")
  @@schema("core")
}

enum MessageSenderType {
  HUMAN
  SYSTEM
  AI

  @@map("message_sender_type")
  @@schema("core")
}

enum MessagingProvider {
  FLW
  DKW

  @@map("messaging_provider")
  @@schema("core")
}

enum MessagingDirection {
  INBOUND
  OUTBOUND

  @@map("messaging_direction")
  @@schema("core")
}

enum MessagingSenderType {
  HUMAN
  SYSTEM
  AI
  BOT

  @@map("messaging_sender_type")
  @@schema("core")
}

enum WhatsAppDepartmentMappingStatus {
  PENDING
  MAPPED

  @@map("whatsapp_department_mapping_status")
  @@schema("core")
}

model FlwSessionRaw {
  id          String   @id @db.Uuid
  clientId    String   @map("client_id")
  payloadJson Json     @map("payload_json")
  source      String
  fetchedAt   DateTime @default(now()) @map("fetched_at")

  @@index([clientId, fetchedAt(sort: Desc)], map: "flw_sessions_client_fetched_at_idx")
  @@map("flw_sessions")
  @@schema("raw")
}

model FlwMessageRaw {
  id          String   @id @db.Uuid
  clientId    String   @map("client_id")
  sessionId   String   @map("session_id") @db.Uuid
  payloadJson Json     @map("payload_json")
  source      String
  fetchedAt   DateTime @default(now()) @map("fetched_at")

  @@index([clientId, sessionId, fetchedAt(sort: Desc)], map: "flw_messages_client_session_fetched_at_idx")
  @@map("flw_messages")
  @@schema("raw")
}

model MessagingSyncState {
  clientId           String    @id @map("client_id")
  provider           String    @default("FLW")
  lastSessionSyncAt  DateTime? @map("last_session_sync_at")
  lastMessageSyncAt  DateTime? @map("last_message_sync_at")
  lastNormalizedAt   DateTime? @map("last_normalized_at")
  lastSuccessAt      DateTime? @map("last_success_at")
  lastError          String?   @map("last_error")
  updatedAt          DateTime  @default(now()) @updatedAt @map("updated_at")

  @@map("messaging_sync_states")
  @@schema("core")
}

model MessagingContact {
  id                 String              @id
  clientId           String              @map("client_id")
  provider           MessagingProvider
  externalContactId  String              @map("external_contact_id")
  displayName        String?             @map("display_name")
  phoneNormalized    String?             @map("phone_normalized")
  legacyContactId    BigInt?             @map("legacy_contact_id")
  rawJson            Json?               @map("raw_json")
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @default(now()) @updatedAt @map("updated_at")
  sessions           MessagingSession[]

  @@unique([clientId, provider, externalContactId], map: "messaging_contacts_client_provider_external_key")
  @@index([clientId, legacyContactId], map: "messaging_contacts_client_legacy_contact_id_idx")
  @@map("messaging_contacts")
  @@schema("core")
}

model MessagingSession {
  id                  String             @id
  clientId            String             @map("client_id")
  branchId            Int?               @map("branch_id")
  provider            MessagingProvider
  externalSessionId   String             @map("external_session_id")
  contactExternalId   String?            @map("contact_external_id")
  contactId           String?             @map("contact_id")
  whatsappCityId        String?       @map("whatsapp_city_id") @db.Uuid
  externalDepartmentId  String?       @map("external_department_id") @db.Uuid
  assignedAgentEmail  String?            @map("assigned_agent_email")
  assignedAgentUserId String?            @map("assigned_agent_user_id")
  status              String?
  startedAt           DateTime           @map("started_at")
  endedAt             DateTime?          @map("ended_at")
  rawJson             Json?              @map("raw_json")
  createdAt           DateTime           @default(now()) @map("created_at")
  updatedAt           DateTime           @default(now()) @updatedAt @map("updated_at")
  branch              Branch?            @relation(fields: [branchId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  contact             MessagingContact?  @relation(fields: [contactId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  whatsappCity          WhatsAppCity? @relation(fields: [whatsappCityId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  messages            MessagingMessage[]

  @@unique([clientId, provider, externalSessionId], map: "messaging_sessions_client_provider_external_key")
  @@index([clientId, startedAt], map: "messaging_sessions_client_started_at_idx")
  @@index([clientId, branchId, startedAt], map: "messaging_sessions_client_branch_started_at_idx")
  @@index([contactId], map: "messaging_sessions_contact_id_idx")
  @@index([clientId, whatsappCityId, startedAt], map: "messaging_sessions_client_whatsapp_city_started_at_idx")
  @@index([clientId, externalDepartmentId], map: "messaging_sessions_client_external_department_idx")
  @@map("messaging_sessions")
  @@schema("core")
}

model MessagingMessage {
  id                String              @id
  clientId          String              @map("client_id")
  sessionId         String              @map("session_id")
  provider          MessagingProvider
  externalMessageId String              @map("external_message_id")
  direction         MessagingDirection
  senderType        MessagingSenderType @map("sender_type")
  messageType       String              @map("message_type")
  bodyText          String              @default("") @map("body_text")
  mediaUrl          String?             @map("media_url")
  mediaType         String?             @map("media_type")
  createdAtExternal DateTime            @map("created_at_external")
  updatedAtExternal DateTime            @map("updated_at_external")
  rawJson           Json?               @map("raw_json")
  createdAt         DateTime            @default(now()) @map("created_at")
  updatedAt         DateTime            @default(now()) @updatedAt @map("updated_at")
  session           MessagingSession    @relation(fields: [sessionId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([clientId, provider, externalMessageId], map: "messaging_messages_client_provider_external_key")
  @@index([sessionId, createdAtExternal], map: "messaging_messages_session_created_at_external_idx")
  @@index([clientId, createdAtExternal], map: "messaging_messages_client_created_at_external_idx")
  @@map("messaging_messages")
  @@schema("core")
}

model WhatsAppCity {
  id        String   @id @db.Uuid
  clientId  String   @map("client_id")
  name      String
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")
  client    SinapseClient @relation(fields: [clientId], references: [id])
  mappings  WhatsAppDepartmentMapping[]
  sessions  MessagingSession[]

  @@unique([clientId, name], map: "whatsapp_cities_client_name_key")
  @@map("whatsapp_cities")
  @@schema("core")
}

model WhatsAppDepartmentMapping {
  id               String                           @id @db.Uuid
  clientId         String                           @map("client_id")
  departmentId     String                           @map("department_id") @db.Uuid
  departmentLabel  String?                          @map("department_label")
  cityId           String?                          @map("city_id") @db.Uuid
  status           WhatsAppDepartmentMappingStatus
  createdAt        DateTime                         @default(now()) @map("created_at")
  updatedAt        DateTime                         @default(now()) @updatedAt @map("updated_at")
  client           SinapseClient                    @relation(fields: [clientId], references: [id])
  city             WhatsAppCity?                    @relation(fields: [cityId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([clientId, departmentId], map: "whatsapp_department_mappings_client_department_key")
  @@index([clientId, status], map: "whatsapp_department_mappings_client_status_idx")
  @@map("whatsapp_department_mappings")
  @@schema("core")
}
